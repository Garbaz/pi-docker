#!/usr/bin/env bash
# =============================================================================
# pi-docker — Run Pi coding agent in an isolated Docker container
# =============================================================================
# Usage:
#   pi-docker                          # Run Pi in the current directory
#   pi-docker --project /path/to/dir   # Specific project directory
#   pi-docker --attach                 # Attach to a running container for this project
#   pi-docker --gpus                   # Run with NVIDIA GPU passthrough
#   pi-docker --host-net               # Use host network (container sees localhost)
#   pi-docker --build                  # Build image then run Pi
#   pi-docker --rebuild                # Clean rebuild from scratch then run Pi
#   pi-docker --extend                 # Force rebuild extended image (auto-detected anyway)
#   pi-docker --shell                  # Drop into a shell inside the container
#   pi-docker --stop                   # Stop all running containers for this project
#   pi-docker --clean                  # Remove containers and project image
#   pi-docker --help                   # Show this help
#
# Each invocation creates its own container (removed automatically on exit).
# Use --attach to join an already running container instead of creating a new one.
# =============================================================================

set -euo pipefail

# --- Configuration ---
PI_DOCKER_DIR="${HOME}/.pi/docker"
BASE_IMAGE="pi-base:latest"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

info()  { echo -e "${BLUE}[pi-docker]${NC} $*"; }
warn()  { echo -e "${YELLOW}[pi-docker]${NC} $*"; }
error() { echo -e "${RED}[pi-docker]${NC} $*" >&2; }
ok()    { echo -e "${GREEN}[pi-docker]${NC} $*"; }

# --- Auto-mount extra paths ---
# Scans remaining args for file/directory paths and mounts them into the container.
# Sets global arrays: EXTRA_MOUNTS (volume args), REWRITTEN_ARGS (modified args)

declare -a EXTRA_MOUNTS=()
declare -a REWRITTEN_ARGS=()
declare -A MOUNTED_PATHS  # dedup: resolved host path -> container path
MOUNT_COUNTER=0

# Check if an arg looks like a path that exists on the host
_is_host_path() {
    local arg="$1"

    # Must look like a path (absolute, relative, or home-relative)
    [[ "$arg" =~ ^(/|\.\.?/|~) ]] || return 1

    # Expand ~ if present
    local expanded
    expanded="$(_expand_tilde "$arg")"

    # Must resolve to an existing path
    realpath -e "$expanded" &>/dev/null || return 1

    return 0
}

# Safely expand ~ and ~/ in a path argument (no eval).
# ~user/foo is not expanded — realpath will reject it and we fall through.
_expand_tilde() {
    local arg="$1"
    if [[ "$arg" == \~ ]]; then
        echo "$HOME"
    elif [[ "$arg" == \~/* ]]; then
        echo "$HOME/${arg#\~/}"
    else
        echo "$arg"
    fi
}

# Mount a single path into the container. Sets CONTAINER_PATH global.
_mount_single_path() {
    local path_arg="$1"
    CONTAINER_PATH="$path_arg"  # default: unchanged

    # Expand ~
    local expanded
    expanded="$(_expand_tilde "$path_arg")"

    local resolved
    resolved="$(realpath -e "$expanded" 2>/dev/null)" || return

    # Dedup: reuse existing mount
    if [[ -n "${MOUNTED_PATHS[$resolved]:-}" ]]; then
        CONTAINER_PATH="${MOUNTED_PATHS[$resolved]}"
        return
    fi

    # Create mount
    local basename
    basename="$(basename "$resolved")"
    local container_mount="/mnt/pi-args/${MOUNT_COUNTER}/${basename}"
    CONTAINER_PATH="$container_mount"

    EXTRA_MOUNTS+=(-v "${resolved}:${container_mount}")
    MOUNTED_PATHS["$resolved"]="$container_mount"
    MOUNT_COUNTER=$((MOUNT_COUNTER + 1))

    info "Auto-mount: ${resolved} → ${container_mount}"
}

# Flags known to take a path argument (value is the next arg).
# Associative array for O(1) lookup — any key set means "takes a path value".
declare -A _PATH_FLAG=(
    ["--extension"]=1 ["-e"]=1
    ["--skill"]=1
    ["--prompt-template"]=1
    ["--theme"]=1
    ["--session"]=1
    ["--fork"]=1
    ["--session-dir"]=1
    ["--export"]=1
    ["--system-prompt"]=1
    ["--append-system-prompt"]=1
)

# Main entry point: scan args, populate EXTRA_MOUNTS and REWRITTEN_ARGS
resolve_extra_mounts() {
    local workspace="$1"
    shift
    local args=("$@")

    EXTRA_MOUNTS=()
    REWRITTEN_ARGS=()
    MOUNTED_PATHS=()
    MOUNT_COUNTER=0

    local i=0
    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"

        # Flag-aware: if this is a path-taking flag, mount the next arg
        if [[ -n "${_PATH_FLAG[$arg]:-}" ]] && [[ $((i + 1)) -lt ${#args[@]} ]]; then
            REWRITTEN_ARGS+=("$arg")
            i=$((i + 1))
            local path_arg="${args[$i]}"
            _mount_single_path "$path_arg"
            REWRITTEN_ARGS+=("$CONTAINER_PATH")
        # Handle @file references: @/path, @./relpath, @~/path
        elif [[ "$arg" =~ ^@(/|\.\.?/|~) ]]; then
            local file_part="${arg#@}"
            if _is_host_path "$file_part"; then
                _mount_single_path "$file_part"
                REWRITTEN_ARGS+=("@${CONTAINER_PATH}")
            else
                REWRITTEN_ARGS+=("$arg")
            fi
        # Generic: standalone arg that looks like a path?
        elif _is_host_path "$arg"; then
            _mount_single_path "$arg"
            REWRITTEN_ARGS+=("$CONTAINER_PATH")
        else
            REWRITTEN_ARGS+=("$arg")
        fi
        i=$((i + 1))
    done
}

# --- Resolve workspace ---
resolve_workspace() {
    local ws="${1:-$(pwd)}"
    ws="$(cd "$ws" 2>/dev/null && pwd)" || {
        error "Workspace directory does not exist: $1"
        exit 1
    }
    echo "$ws"
}

# --- Project slug from directory name (for image/container naming) ---
project_slug() {
    basename "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/^-\|-$//g'
}

# --- Project mount name (preserves case, for the container workdir path) ---
project_mount_name() {
    basename "$1"
}

# --- Build base image ---
build_base() {
    local no_cache=""
    [[ "${1:-}" == "--no-cache" ]] && no_cache="--no-cache"

    docker build \
        ${no_cache} \
        --build-arg HOST_UID="$(id -u)" \
        --build-arg HOST_GID="$(id -g)" \
        -t "${BASE_IMAGE}" \
        "${PI_DOCKER_DIR}/"
    ok "Base image built: ${BASE_IMAGE}"
}

# --- Build project-extended image ---
build_extended() {
    local workspace="$1"
    local slug
    slug="$(project_slug "$workspace")"
    local extend_file="${workspace}/.pi-dockerfile"
    local project_image="pi-${slug}:latest"

    if [[ ! -f "$extend_file" ]]; then
        warn "No .pi-dockerfile found in ${workspace}"
        warn "Copy the template: cp ${PI_DOCKER_DIR}/.pi-dockerfile.template ${workspace}/.pi-dockerfile"
        info "Falling back to base image ${BASE_IMAGE}"
        return
    fi

    if ! docker image inspect "${BASE_IMAGE}" &>/dev/null; then
        error "Base image not found. Run: pi-docker --build"
        exit 1
    fi

    info "Building extended image ${project_image} from ${extend_file}..."
    docker build \
        --pull \
        --build-arg HOST_UID="$(id -u)" \
        --build-arg HOST_GID="$(id -g)" \
        -t "${project_image}" \
        -f "${extend_file}" \
        "${workspace}/"
    ok "Extended image built: ${project_image}"
}

# --- Compare two Docker image timestamps ---
# Returns 0 (true) if image_a is newer than image_b.
_image_newer_than() {
    local image_a="$1" image_b="$2"
    local ctime_a ctime_b epoch_a epoch_b
    ctime_a="$(docker image inspect "${image_a}" --format '{{.Created}}' 2>/dev/null)" || return 1
    ctime_b="$(docker image inspect "${image_b}" --format '{{.Created}}' 2>/dev/null)" || return 1
    epoch_a="$(date -d "${ctime_a}" '+%s' 2>/dev/null)" || return 1
    epoch_b="$(date -d "${ctime_b}" '+%s' 2>/dev/null)" || return 1
    [[ "${epoch_a}" -gt "${epoch_b}" ]]
}

# --- Check if base image needs rebuilding and warn ---
check_stale_image() {
    if ! docker image inspect "${BASE_IMAGE}" &>/dev/null; then
        error "Base image not found. Run: pi-docker --build"
        exit 1
    fi

    local dockerfile_mtime image_ctime image_epoch
    dockerfile_mtime="$(stat -c '%Y' "${PI_DOCKER_DIR}/Dockerfile" 2>/dev/null)" || return
    image_ctime="$(docker image inspect "${BASE_IMAGE}" --format '{{.Created}}' 2>/dev/null)" || return
    image_epoch="$(date -d "${image_ctime}" '+%s' 2>/dev/null)" || return

    if [[ "${dockerfile_mtime}" -gt "${image_epoch}" ]]; then
        warn "Dockerfile changed since last build. Run: pi-docker --rebuild for a clean rebuild"
    fi
}

# --- Resolve which image to use (extended if available, otherwise base) ---
# Automatically builds the extended image if .pi-dockerfile exists and is needed.
resolve_image() {
    local workspace="$1"
    local slug
    slug="$(project_slug "$workspace")"
    local project_image="pi-${slug}:latest"
    local extend_file="${workspace}/.pi-dockerfile"

    # No .pi-dockerfile → use base image
    if [[ ! -f "$extend_file" ]]; then
        echo "${BASE_IMAGE}"
        return
    fi

    # Auto-build extended image if it doesn't exist yet
    if ! docker image inspect "${project_image}" &>/dev/null; then
        build_extended "$workspace" >&2
    # Or rebuild if base image is newer (e.g. NODE_PATH was added to Dockerfile)
    elif _image_newer_than "${BASE_IMAGE}" "${project_image}"; then
        info "Base image was rebuilt — rebuilding extended image" >&2
        build_extended "$workspace" >&2
    fi

    # Return extended image if it exists now (build may have failed)
    if docker image inspect "${project_image}" &>/dev/null; then
        echo "${project_image}"
        ok "Using extended image: ${project_image}" >&2
    else
        warn "Extended image build failed or not found, falling back to base image" >&2
        echo "${BASE_IMAGE}"
    fi
}

# --- Generate a unique container name (retries if colliding) ---
container_name() {
    local slug="$1"
    local cname attempts=0
    while [[ $attempts -lt 5 ]]; do
        local suffix
        suffix="$(head -c 4 /dev/urandom | xxd -p)"
        cname="pi-${slug}-${suffix}"
        if ! docker ps -aq --filter "name=${cname}" 2>/dev/null | grep -q .; then
            echo "${cname}"
            return
        fi
        attempts=$((attempts + 1))
    done
    error "Could not find a unique container name after 5 attempts"
    exit 1
}

# --- Find running containers for a project ---
find_running_containers() {
    local slug="$1"
    docker ps --filter "name=pi-${slug}-" --format '{{.Names}}' 2>/dev/null
}

# --- Build common docker run args into DOCKER_ARGS (global array) ---
# Sets: DOCKER_ARGS, CONTAINER_NAME, CONTAINER_WORKDIR
build_docker_args() {
    local workspace="$1"
    local slug
    slug="$(project_slug "$workspace")"
    local mount_name
    mount_name="$(project_mount_name "$workspace")"
    CONTAINER_WORKDIR="/home/agent/${mount_name}"
    CONTAINER_NAME="$(container_name "$slug")"
    local use_image
    use_image="$(resolve_image "$workspace")"

    # TTY
    if [[ -t 0 ]]; then
        DOCKER_ARGS=("-it")
    else
        DOCKER_ARGS=("-i")
    fi

    DOCKER_ARGS+=(
        --rm
        --name "${CONTAINER_NAME}"
        --init
    )

    # GPU passthrough
    if [[ "$gpu_passthrough" -eq 1 ]]; then
        DOCKER_ARGS+=(--gpus all)
    fi

    # Host networking
    if [[ "$host_network" -eq 1 ]]; then
        DOCKER_ARGS+=(--network host)
    fi

    # Environment
    DOCKER_ARGS+=(
        -e "HOME=/home/agent"
        -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}"
        -e "OPENAI_API_KEY=${OPENAI_API_KEY:-}"
        -e "OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}"
        -e "GITHUB_TOKEN=${GITHUB_TOKEN:-}"
        -e "PI_IN_DOCKER=1"
    )

    # Volume mounts
    DOCKER_ARGS+=(
        -v "${workspace}:${CONTAINER_WORKDIR}"
        -v "${HOME}/.pi/agent:/home/agent/.pi/agent"
        -v "${PI_DOCKER_DIR}/permission-config.json:/home/agent/.pi/agent/extensions/pi-permission-system/config.json:ro"
        -v "${HOME}/.pi/docker/npm-global:/home/agent/.npm-global"
    )

    # Extra mounts for paths detected in forwarded args
    if [[ ${#EXTRA_MOUNTS[@]} -gt 0 ]]; then
        DOCKER_ARGS+=("${EXTRA_MOUNTS[@]}")
    fi

    # Optional mounts (only if host files exist)
    [[ -f "${HOME}/.gitconfig" ]] && DOCKER_ARGS+=(-v "${HOME}/.gitconfig:/home/agent/.gitconfig:ro")
    [[ -f "${HOME}/.ssh/known_hosts" ]] && DOCKER_ARGS+=(-v "${HOME}/.ssh/known_hosts:/home/agent/.ssh/known_hosts:ro")

    # Working directory and image
    DOCKER_ARGS+=(
        -w "${CONTAINER_WORKDIR}"
        "${use_image}"
    )

    info "Workspace: ${workspace} → ${CONTAINER_WORKDIR}"
    info "Image: ${use_image}"
}

# --- Run Pi container ---
run_pi() {
    local workspace="$1"
    local extra_args=("${@:2}")

    # Resolve and mount extra paths from forwarded args
    resolve_extra_mounts "$workspace" "${extra_args[@]}"
    extra_args=("${REWRITTEN_ARGS[@]}")

    build_docker_args "$workspace"
    info "Starting Pi in container '${CONTAINER_NAME}'..."
    docker run "${DOCKER_ARGS[@]}" "${extra_args[@]}"
}

# --- Drop into shell ---
run_shell() {
    local workspace="$1"

    build_docker_args "$workspace"
    info "Opening shell in container '${CONTAINER_NAME}'..."
    docker run "${DOCKER_ARGS[@]}" --entrypoint /bin/bash
}

# --- Attach to a running container (exec a second Pi into it) ---
attach_pi() {
    local workspace="$1"
    local slug
    slug="$(project_slug "$workspace")"
    local extra_args=("${@:2}")

    # Resolve and mount extra paths from forwarded args
    resolve_extra_mounts "$workspace" "${extra_args[@]}"
    # NOTE: extra mounts can't be added to a running container via docker exec.
    # If paths were detected, warn and exit.
    if [[ ${#EXTRA_MOUNTS[@]} -gt 0 ]]; then
        error "Extra paths detected but --attach cannot add mounts to a running container"
        error "Start a new container instead: pi-docker ${REWRITTEN_ARGS[*]}"
        exit 1
    fi
    extra_args=("${REWRITTEN_ARGS[@]}")

    local containers
    containers="$(find_running_containers "$slug")"
    if [[ -z "$containers" ]]; then
        error "No running container for project '${slug}'"
        error "Start one first: pi-docker"
        exit 1
    fi

    local count cname
    count="$(echo "$containers" | wc -l)"
    if [[ "$count" -gt 1 ]]; then
        warn "Multiple containers running for '${slug}':"
        echo "$containers" | while read -r name; do
            warn "  $name"
        done
        cname="$(echo "$containers" | head -1)"
        warn "Attaching to: ${cname}"
    else
        cname="$(echo "$containers" | head -1)"
    fi

    info "Attaching to container '${cname}'..."
    docker exec -it "${cname}" pi "${extra_args[@]}"
}

# --- Stop all containers for a project ---
stop_container() {
    local workspace="$1"
    local slug
    slug="$(project_slug "$workspace")"

    local containers
    containers="$(docker ps --filter "name=pi-${slug}-" --format '{{.Names}}' 2>/dev/null)" || true

    if [[ -z "${containers}" ]]; then
        warn "No running containers for project '${slug}'"
        return
    fi

    for cname in ${containers}; do
        info "Stopping ${cname}..."
        if docker stop "${cname}" 2>/dev/null; then
            ok "Stopped ${cname}"
        else
            warn "Could not stop ${cname}"
        fi
    done
}

# --- Clean up ---
clean() {
    local workspace="$1"
    local slug
    slug="$(project_slug "$workspace")"
    local project_image="pi-${slug}:latest"

    info "Cleaning up Pi containers and images for project '${slug}'..."

    local containers
    containers="$(docker ps -a --filter "name=pi-${slug}-" --format '{{.Names}}' 2>/dev/null)" || true
    for cname in ${containers}; do
        docker rm -f "${cname}" &>/dev/null || true
    done

    if docker image inspect "${project_image}" &>/dev/null; then
        if ! docker rmi "${project_image}" 2>/dev/null; then
            warn "Could not remove image ${project_image}"
        else
            ok "Removed image ${project_image}"
        fi
    fi

    ok "Clean complete for '${slug}'"
}

# --- Help ---
show_help() {
    cat <<EOF
${GREEN}pi-docker${NC} — Run Pi coding agent in an isolated Docker container

${BLUE}USAGE${NC}
  pi-docker [OPTIONS] [PI_ARGS...]

${BLUE}OPTIONS${NC}
  --project DIR    Use DIR as workspace (default: current directory)
  --attach         Attach to a running container for this project
  --gpus           Pass all NVIDIA GPUs to the container (--gpus all)
  --host-net       Use host network namespace (container sees localhost)
  --build          Build the base image then run Pi
  --rebuild        Clean rebuild from scratch (no cache) then run Pi
  --build-only     Build the base image without running Pi
  --extend         Force rebuild the project-extended image (.pi-dockerfile)
  --shell          Drop into a bash shell inside the container
  --stop           Stop all running containers for this project
  --clean          Remove containers and project-specific image
  --help           Show this help message

${BLUE}MULTIPLE INSTANCES${NC}
  Each pi-docker invocation creates its own container (removed on exit).
  To join an already running container instead, use --attach:

    pi-docker              # Start a new Pi session
    pi-docker --attach     # Join the running container for this project

  --stop stops all running containers for the project.

${BLUE}GPU PASSTHROUGH${NC}
  Pass --gpus to enable NVIDIA GPU access inside the container.
  Requires the NVIDIA Container Toolkit on the host.

    pi-docker --gpus       # Start Pi with GPU access

${BLUE}HOST NETWORKING${NC}
  By default the container uses Docker's bridge network (isolated).
  Pass --host-net to share the host's network namespace — the container
  can reach services on localhost (e.g. local STT/LLM servers).

    pi-docker --host-net   # Container uses host network

  Note: --host-net and --gpus can be combined.

${BLUE}PROJECT EXTENSIONS${NC}
  To add project-specific dependencies:

  1. Copy the template:
     cp ~/.pi/docker/.pi-dockerfile.template ./.pi-dockerfile

  2. Edit .pi-dockerfile (it starts FROM pi-base:latest):
     RUN apt-get update && apt-get install -y libpq-dev
     RUN uv pip install --system numpy pandas

  3. Run Pi — the extended image is detected and built automatically:
     pi-docker

  Use --extend to force a rebuild after editing .pi-dockerfile.

${BLUE}ENVIRONMENT VARIABLES${NC}
  ANTHROPIC_API_KEY   Passed through to the container
  OPENAI_API_KEY      Passed through to the container
  OPENROUTER_API_KEY  Passed through to the container
  GITHUB_TOKEN        Passed through to the container

${BLUE}FILES${NC}
  ~/.pi/docker/Dockerfile                  Base Pi image definition
  ~/.pi/docker/.pi-dockerfile.template  Template for project extensions
  ~/.pi/docker/permission-config.json      YOLO mode config for the container
  ./.pi-dockerfile                      Project-specific image extensions

EOF
}

# --- Main ---
main() {
    local workspace=""
    local action="run"
    local gpu_passthrough=0
    local host_network=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --project)
                workspace="$2"
                shift 2
                ;;
            --attach)
                action="attach"
                shift
                ;;
            --gpus)
                gpu_passthrough=1
                shift
                ;;
            --host-net)
                host_network=1
                shift
                ;;
            --rebuild)
                action="rebuild"
                shift
                ;;
            --build)
                action="build"
                shift
                ;;
            --build-only)
                action="build-only"
                shift
                ;;
            --extend)
                action="extend"
                shift
                ;;
            --shell)
                action="shell"
                shift
                ;;
            --stop)
                action="stop"
                shift
                ;;
            --clean)
                action="clean"
                shift
                ;;
            --help|-h)
                show_help
                exit 0
                ;;
            --)
                shift
                break
                ;;
            *)
                break
                ;;
        esac
    done

    # Resolve workspace
    workspace="$(resolve_workspace "${workspace:-$(pwd)}")"

    case "${action}" in
        run)
            check_stale_image
            run_pi "${workspace}" "$@"
            ;;
        attach)
            attach_pi "${workspace}" "$@"
            ;;
        build)
            build_base
            run_pi "${workspace}" "$@"
            ;;
        rebuild)
            build_base --no-cache
            run_pi "${workspace}" "$@"
            ;;
        build-only)
            build_base
            ;;
        extend)
            build_extended "${workspace}"
            ;;
        shell)
            check_stale_image
            run_shell "${workspace}"
            ;;
        stop)
            stop_container "${workspace}"
            ;;
        clean)
            clean "${workspace}"
            ;;
    esac
}

main "$@"
